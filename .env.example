# ─────────────────────────────────────────────────────────────────────────────
# NEXA Copilot — Evaluation Sandbox · SYNTHETIC settings only.
# No client data, no real credentials. Copy to `.env` and set your own API key.
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
AI_COPILOT_PORT=3110

# Sandbox Postgres (pgvector) + Redis. See HANDOFF.md for the docker run commands
# that bring these up on these ports.
DATABASE_HOST=localhost
DATABASE_PORT=5544
DATABASE_USER=ems_admin
DATABASE_PASSWORD=sandbox_pw
DATABASE_NAME=ai_sandbox
REDIS_HOST=localhost
REDIS_PORT=6390

# Industry packs ship at the repo root of this sandbox. run-copilot.sh sets this
# to an absolute path automatically; if you launch node yourself, use an abs path.
PACKS_ROOT=./packs
SYNTHETIC_DATA_LABEL=SynthBank (synthetic)

# REQUIRED to score the REAL Copilot — replace with YOUR OWN Anthropic key.
# (The day-one mock at :8899 needs no key at all.)
ANTHROPIC_API_KEY=sk-ant-REPLACE-WITH-YOUR-OWN-KEY
